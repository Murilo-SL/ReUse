# url ou dominio
@URL = http://localhost
# Porta do servidor
@PORT = 3600
# endpoint ou rota do teste
@ENDPOINT = auth
# uri - rota final do teste
@URI = {{URL}}:{{PORT}}/{{ENDPOINT}}

###
POST {{URI}}/login
Content-Type: application/json; charset=utf-8

  {    
      "email": "teste@gmail.com",
      "password": "123456789"
  }

